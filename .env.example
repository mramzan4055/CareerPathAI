# Supabase (Project Settings -> API)
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_KEY="your-anon-public-key"
# Service role key bypasses RLS -- required for the backend to write CVs/jobs/saved_jobs.
# If unset, database.py falls back to SUPABASE_KEY (anon), which relies entirely on RLS policies.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Groq (primary LLM for resume parsing / skill-gap analysis)
GROQ_API_KEY="gsk_..."

# Gemini (fallback LLM, used when Groq fails)
GEMINI_API_KEY="your-gemini-api-key"

# Adzuna (job search)
ADZUNA_APP_ID="your-adzuna-app-id"
ADZUNA_APP_KEY="your-adzuna-app-key"

# Comma-separated list of origins allowed to call this API
FRONTEND_ORIGINS="http://localhost:3000"
