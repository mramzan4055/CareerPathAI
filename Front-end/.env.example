# Supabase (Project Settings -> API) -- browser-safe values only
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"

# URL of the FastAPI backend (Backend/)
NEXT_PUBLIC_BACKEND_URL="http://127.0.0.1:8000"

# Server-only Supabase client (src/lib/supabase.ts). Only needed if that file
# is actually used server-side -- as of this writing nothing in src/ imports it.
# Never prefix these with NEXT_PUBLIC_: doing so bundles them into client JS.
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
